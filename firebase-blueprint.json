{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A score for a specific module exercise",
      "type": "object",
      "properties": {
        "correct": {
          "type": "number",
          "description": "Number of correct answers"
        },
        "total": {
          "type": "number",
          "description": "Total number of questions"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date when the exercise was completed"
        }
      },
      "required": ["correct", "total", "date"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing scores and advice",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "scores": {
          "type": "object",
          "description": "Scores grouped by module type",
          "properties": {
            "Leseverstehen": { "type": "array", "items": { "$ref": "#/entities/Score" } },
            "Hörverstehen": { "type": "array", "items": { "$ref": "#/entities/Score" } },
            "Sprachbausteine": { "type": "array", "items": { "$ref": "#/entities/Score" } },
            "Schriftlicher Ausdruck": { "type": "array", "items": { "$ref": "#/entities/Score" } },
            "Mündlicher Ausdruck": { "type": "array", "items": { "$ref": "#/entities/Score" } },
            "Grammatik": { "type": "array", "items": { "$ref": "#/entities/Score" } }
          }
        },
        "overallAdvice": {
          "type": "string",
          "description": "Overall advice generated by AI"
        }
      },
      "required": ["uid", "email", "scores"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profiles containing their scores and progress"
    }
  }
}
